      "sans": ["Inter", "system-ui", "-apple-system", "Segoe UI", "Roboto", "sans-serif"],
      "mono": ["JetBrains Mono", "Consolas", "monospace"]
    },
    "scale": {
      "display": { "size": "32px", "weight": "700", "lineHeight": "40px", "letterSpacing": "-0.02em" },
      "h1": { "size": "24px", "weight": "600", "lineHeight": "32px", "letterSpacing": "-0.01em" },
      "h2": { "size": "20px", "weight": "600", "lineHeight": "28px", "letterSpacing": "0" },
      "h3": { "size": "16px", "weight": "600", "lineHeight": "24px", "letterSpacing": "0" },
      "body": { "size": "15px", "weight": "400", "lineHeight": "22px", "letterSpacing": "0" },
      "bodySmall": { "size": "13px", "weight": "400", "lineHeight": "18px", "letterSpacing": "0" },
      "caption": { "size": "12px", "weight": "400", "lineHeight": "16px", "letterSpacing": "0" },
      "label": { "size": "11px", "weight": "600", "lineHeight": "16px", "letterSpacing": "0.04em" }
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px"
  },
  "radius": {
    "none": "0px",
    "sm": "6px",
    "md": "10px",
    "lg": "14px",
    "xl": "20px",
    "full": "9999px"
  },
  "shadow": {
    "xs": "0 1px 2px 0 rgba(15, 20, 16, 0.05)",
    "sm": "0 1px 3px 0 rgba(15, 20, 16, 0.08), 0 1px 2px 0 rgba(15, 20, 16, 0.04)",
    "md": "0 4px 6px -1px rgba(15, 20, 16, 0.08), 0 2px 4px -2px rgba(15, 20, 16, 0.04)",
    "lg": "0 10px 15px -3px rgba(15, 20, 16, 0.08), 0 4px 6px -4px rgba(15, 20, 16, 0.04)",
    "xl": "0 20px 25px -5px rgba(15, 20, 16, 0.10), 0 8px 10px -6px rgba(15, 20, 16, 0.04)"
  },
  "border": {
    "width": {
      "thin": "1px",
      "default": "2px",
      "thick": "4px"
    },
    "color": "#D8DDD4"
  },
  "transition": {
    "fast": "150ms ease",
    "default": "200ms ease",
    "slow": "300ms ease"
  }
}